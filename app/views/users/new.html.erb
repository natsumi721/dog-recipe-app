<div class="top-container">

  <h1 class="accent">新規登録</h1>
  <p class="sub-text">ワンちゃんのためのレシピ管理を始めましょう</p>

  <div class="recipe-card p-4 mt-4" style="max-width:400px;margin:auto;">
    <%= render "form", submit_text: "登録する" %>

    <!-- Google OAuth 登録ボタン -->
    <div class="text-center mt-4">
      <p class="note">または</p>
      <%= link_to auth_at_provider_path(provider: :google), class: "secondary-button d-flex align-items-center justify-content-center gap-2", style: "max-width:400px;margin:auto;" do %>
        <%= image_tag "google-icon.png", alt: "Google", style: "width:20px;height:20px;" %>
        <span>Google で登録</span>
      <% end %>
    </div>
  </div>
   
  <p class="note mt-4">
    すでにアカウントをお持ちですか？
  </p>

  <%= link_to "登録済みの方はこちら", login_path, class:"secondary-button" %><br>
  <%= link_to "戻る", root_path, class:"secondary-button" %>
</div>