<div class="container mx-auto px-4 py-8">
  <div class="max-w-md mx-auto bg-white rounded-lg shadow-md p-6">
    <h2 class="text-2xl font-bold mb-6 text-center">追加情報の入力</h2>
    
    <p class="text-gray-600 mb-6">
      アカウントの登録を完了するため、以下の情報を入力してください。
    </p>

    <%= form_with model: @user, url: update_registration_path, method: :patch, local: true do |f| %>
      <%= render 'shared/error_messages', object: f.object %>

      <div class="mb-4">
        <%= f.label :last_name, '姓', class: 'block text-sm font-medium text-gray-700 mb-2' %>
        <%= f.text_field :last_name, class: 'w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500', placeholder: '山田' %>
      </div>

      <div class="mb-4">
        <%= f.label :first_name, '名', class: 'block text-sm font-medium text-gray-700 mb-2' %>
        <%= f.text_field :first_name, class: 'w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500', placeholder: '太郎' %>
      </div>

      <div class="mb-6">
        <%= f.label :nickname, 'ニックネーム', class: 'block text-sm font-medium text-gray-700 mb-2' %>
        <%= f.text_field :nickname, class: 'w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500', placeholder: 'やまちゃん' %>
      </div>

      <div class="flex justify-center">
        <%= f.submit '登録を完了する', class: 'w-full bg-blue-500 hover:bg-blue-600 text-white font-bold py-2 px-4 rounded-md transition duration-200' %>
      </div>
    <% end %>
  </div>
</div>