<div class="container mt-3 mt-md-5 px-3" style="max-width: 600px;">
  <div class="card shadow p-3 p-md-4 rounded-4">
    <h2 class="text-center mb-3 mb-md-4 fw-bold fs-4 fs-md-3">追加情報の入力</h2>

    <p class="text-center text-muted mb-3 mb-md-4 small">
      アカウントの登録を完了するため、以下の情報を入力してください。
    </p>

    <%= form_with model: @user, url: update_registration_path, method: :patch, local: true do |f| %>
      <%= render 'shared/error_messages', object: f.object %>

      <!-- 姓 -->
      <div class="mb-3 mb-md-4">
        <%= f.label :last_name, '姓', class: 'form-label fw-bold' %>
        <%= f.text_field :last_name, class: 'form-control form-control-lg rounded-pill', placeholder: '山田' %>
      </div>

      <!-- 名 -->
      <div class="mb-3 mb-md-4">
        <%= f.label :first_name, '名', class: 'form-label fw-bold' %>
        <%= f.text_field :first_name, class: 'form-control form-control-lg rounded-pill', placeholder: '太郎' %>
      </div>

      <!-- ニックネーム -->
      <div class="mb-3 mb-md-4">
        <%= f.label :nickname, 'ニックネーム', class: 'form-label fw-bold' %>
        <%= f.text_field :nickname, class: 'form-control form-control-lg rounded-pill', placeholder: 'やまちゃん' %>
      </div>

      <!-- 登録ボタン -->
      <div class="d-grid">
        <%= f.submit '登録を完了する', class: 'btn btn-warning btn-lg rounded-pill fw-bold text-white' %>
      </div>
    <% end %>

    <!-- 戻るボタン -->
    <div class="text-center mt-3 mt-md-4">
      <%= link_to '← 戻る', root_path, class: 'btn btn-secondary btn-lg w-100 w-md-auto' %>
    </div>
  </div>
</div>