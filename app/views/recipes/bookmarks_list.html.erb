<div class="container mt-5">
  <div class="text-center mb-5">
    <h1 class="text-center mb-4 fw-bold"><%= @dog.name %> ちゃんのブックマーク</h1>
    <p class="lead">お気に入りのレシピ一覧</p>
  </div>

      <div class="row g-4">
    <% if @bookmark_recipes.present? %>
      <% @bookmark_recipes.each do |recipe| %>
        <div class="col-md-4">
        <div class="card recipe-card h-100 shadow-sm p-4 text-center d-flex flex-column">
    
              <h5 class="fw-bold mb-3"><%= recipe.name %></h5>
              <p class="text-muted small mb-4"><%= recipe.description %></p>
              <%= link_to "詳細を見る", recipe_path(recipe, dog_id: @dog.id, return_to: request.fullpath), class:  "btn btn-warning rounded-pill px-4 text-white mt-auto" %>
            </div>
          </div>
      <% end %>
    </div>
  <% else %>
    <div class="alert alert-info text-center">
      まだブックマークがありません
    </div>
  <% end %>

  <div class="back-button-container">
    <%= link_to "戻る", dashboard_path,  class: "back-button" %>
  </div>
