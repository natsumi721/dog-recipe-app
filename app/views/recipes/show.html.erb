<div class="container mt-5" style="max-width: 800px;">
  <div class="card shadow-lg p-5 rounded-4 border-0">

    <!-- タイトル -->
    <h2 class="fw-bold mb-3 text-center" style="color: #f4a300;">
      🐶 <%= @recipe.name %>
    </h2>

    <!-- 説明 -->
    <p class="text-muted text-center mb-4 fs-5">
      <%= @recipe.description %>
    </p>

    <hr class="my-4">

    <!-- 材料 -->
    <div class="mb-4">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="fw-bold mb-0" style="color: #f4a300;">
          🥕 材料
        </h5>
        <!-- ブックマークボタン（ログインユーザーのみ表示） -->
        <% if logged_in? %>
          <div>
            <% if @bookmark.present? %>
                <%= button_to bookmark_path(@bookmark), method: :delete, class: "btn btn-link p-0 border-0", style: "font-size: 0.9rem; text-decoration: none; font-family: 'Hiragino Maru Gothic ProN', 'メイリオ', sans-serif; color: #999; filter: grayscale(100%);" do %>
                 <span style="filter: grayscale(0%);">🦴 ブックマークを外す 🦴</span>
             <% end %>
          <% else %>
            <%= button_to bookmarks_path(recipe_id: @recipe.id), method: :post, class: "btn btn-link p-0 border-0", style: "font-size: 0.9rem; text-decoration: none; font-family: 'Hiragino Maru Gothic ProN', 'メイリオ', sans-serif; color: #ff6b9d; " do %>
            <span>🦴 ブックマーク 🦴</span>
          <% end %>
        <% end %>
          </div>
        <% end %>
      </div>
      <div class="bg-light p-3 rounded-3">
        <%= simple_format(@recipe.ingredients) %>
      </div>
    </div>

    <!-- 作り方 -->
    <div class="mb-4">
      <h5 class="fw-bold mb-3" style="color: #f4a300;">
        🍳 作り方
      </h5>
      <div class="bg-light p-3 rounded-3">
        <%= simple_format(@recipe.instructions) %>
      </div>
    </div>

    <!-- 栄養ポイント -->
    <div class="mb-4">
      <h5 class="fw-bold mb-3" style="color: #f4a300;">
        🌟 栄養ポイント
      </h5>
      <div class="bg-warning bg-opacity-25 p-3 rounded-3">
        <%= simple_format(@recipe.nutrition_note) %>
      </div>
    </div>

    <!-- 戻るボタン -->
    <div class="text-center mt-4">
      <%= link_to "← 戻る",
            request.referer || recipes_path,
            class: "btn btn-warning rounded-pill px-5 fw-bold text-white shadow-sm" %>
    </div>
  </div>
</div>
