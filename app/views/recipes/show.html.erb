<div class="container mt-5" style="max-width: 800px;">
  <div class="card shadow-lg p-5 rounded-4 border-0">

    <!-- タイトル -->
    <h2 class="fw-bold mb-3 text-center" style="color: #f4a300;">
      🐶 <%= @recipe.name %>
    </h2>

    <!-- 説明 -->
    <p class="text-muted text-center mb-4 fs-5">
      <%= @recipe.description %>
    </p>

    <hr class="my-4">

    <!-- 材料 -->
    <div class="mb-4">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="fw-bold mb-0" style="color: #f4a300;">
          🥕 材料
        </h5>
        
        <!-- ブックマークボタン（ログインユーザーのみ表示） -->
        <% if logged_in? %>
          <div>
            <% if @bookmark.present? %>
              <%= link_to bookmark_path(@bookmark, return_to: request.fullpath), 
                        data: { turbo_method: :delete, turbo_confirm: "本当にブックマークを外しますか?" },
                        class: "btn btn-link p-0 border-0", 
                        style: "font-size: 0.9rem; text-decoration: none; font-family: 'Hiragino Maru Gothic ProN', 'メイリオ', sans-serif; color: #999; filter: grayscale(100%);" do %>
                <span style="filter: grayscale(0%);">🦴 ブックマークを外す 🦴</span>
              <% end %>
            <% else %>
              <%= link_to bookmarks_path(recipe_id: @recipe.id, dog_id: @dog&.id, return_to: request.fullpath), 
                        data: { turbo_method: :post },
                        class: "btn btn-link p-0 border-0", 
                        style: "font-size: 0.9rem; text-decoration: none; font-family: 'Hiragino Maru Gothic ProN', 'メイリオ', sans-serif; color: #ff6b9d;" do %>
                <span>🦴 ブックマーク 🦴</span>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>

      
        <p class="text-muted mb-3" style="font-size: 0.9rem;">
          4食分の分量です。4回に分けて与えてください。また、初めて使う食材は少量から試してください。
        </p>
        
  
      <!-- 犬情報の表示 -->
      <% if @dog.present? && params[:from] != "my_recipes" %>
        <div class="alert alert-info mb-3">
          <strong><%= @dog.name %></strong> ちゃん用に調整されています
          (サイズ: <%= @dog.size_i18n %> / 
           年齢: <%= @dog.age_stage_i18n %> / 
           体型: <%= @dog.body_type_i18n %> /
           運動量: <%= @dog.activity_level_i18n %>)
        </div>
      <% end %>

        <!-- 犬のサイズに応じた材料を表示 -->
        <div class="bg-light p-3 rounded-3 mt-3">
        <% if @adjusted_ingredients.present? %>
          <ul class="list-unstyled mb-0">
            <% @adjusted_ingredients.each do |ingredient| %>
              <li class="mb-2">
                <strong><%= ingredient[:name] || ingredient["name"] %>:</strong> 
                <%= ingredient[:amount] || ingredient["amount"] %><%= ingredient[:unit] || ingredient["unit"] %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-muted mb-0">材料情報がありません</p>
        <% end %>
      </div>
    </div>
    

    <!-- 作り方 -->
    <div class="mb-4">
      <h5 class="fw-bold mb-3" style="color: #f4a300;">
        🍳 作り方
      </h5>
      <div class="bg-light p-3 rounded-3">
        <%= simple_format(@recipe.instructions) %>
      </div>
    </div>

    <!-- 栄養ポイント -->
    <div class="mb-4">
      <h5 class="fw-bold mb-3" style="color: #f4a300;">
        🌟 栄養ポイント
      </h5>
      <div class="bg-warning bg-opacity-25 p-3 rounded-3">
        <%= simple_format(@recipe.nutrition_note) %>
      </div>
    </div>

    <!-- SNSシェアボタン -->
    <div class="text-center mt-4">
      <% share_text = "#{@recipe.name} をチェック！🐶🍽️" %>
      <% share_url = recipe_url(@recipe) %>
      <% hashtags = "犬ごはん,手作り犬ごはん" %>

      <%= link_to "🐾 Xでシェアする",
        "https://twitter.com/intent/tweet?text=#{CGI.escape(share_text)}&url=#{CGI.escape(share_url)}&hashtags=#{hashtags}",
        target: "_blank",
        rel: "noopener",
        class: "btn px-4 py-2",
        style: "
          background-color: #444;
          color: white;
          border-radius: 30px;
          font-weight: bold;
          transition: 0.2s;
        ",
        onmouseover: "this.style.backgroundColor='#666'",
        onmouseout: "this.style.backgroundColor='#444'" %>
    </div>

    <!-- URLコピーボタン -->
    <div class="text-center mt-3">
      <button onclick="copyToClipboard()" 
        class="btn px-4 py-2"
        style="
          background-color: #f4a300;
          color: white;
          border-radius: 30px;
          font-weight: bold;
        ">
        📋 URLをコピー
      </button>
    </div>

    <script>
    function copyToClipboard() {
      const url = "<%= recipe_url(@recipe) %>";
      navigator.clipboard.writeText(url);
      alert("URLをコピーしました！Instagramなどでシェアしてね🐶📸");
    }
    </script>

    <% if @recipe.user.present? %>
      <div class="text-center mt-4 mb-3">
        <p class="text-muted" style="font-size: 0.95rem;">
          <%= @recipe.user.nickname %>さん考案レシピ🍴
        </p>
      </div>
    <% end %>


    <!-- 戻るボタン -->
    <div class="back-button-container">
      <%= link_to " 戻る ",
            @return_to.presence || recipes_path,
            class: "back-button" %>
    </div>
  </div>
</div>