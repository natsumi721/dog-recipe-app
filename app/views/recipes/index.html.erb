<div class="container mt-5">
  <h2 class="text-center mb-4 fw-bold">おすすめレシピ</h2>

  <div class="row g-4">
    <% @recipes.each do |recipe| %>
      <div class="col-md-4">
        <div class="card recipe-card h-100 shadow-sm p-4 text-center d-flex flex-column">
          <h5 class="fw-bold mb-3"><%= recipe.name %></h5>
          <p class="text-muted small mb-4">
            <%= recipe.description %>
          </p>

          <%= link_to "詳細を見る",
                recipe_path(recipe,  dog_id: @dog&.id, return_to: recipes_path(dog_id: @dog&.id)),
                class: "btn btn-warning rounded-pill px-4 text-white mt-auto" %>
        </div>
      </div>
    <% end %>
    <div>

     <!-- シャッフルボタンを追加 -->
  <div class="text-center mb-4">
    <%= link_to "レシピをシャッフル", recipes_path(
          dog_id: @dog&.id,
          age_stage: params[:age_stage],
          body_type: params[:body_type],
          activity_level: params[:activity_level],
          size: params[:size],
          allergies: params[:allergies],
          shuffle: true
        ),
        class: "btn btn-outline-warning px-4" %>
  </div>

    <div class="text-center mt-4">
    <% if current_user %>
  <!-- ログインユーザーには「ダッシュボードへ」ボタンのみ表示 -->
  <%= link_to "ホームに戻る", dashboard_path,
      class: "btn btn-secondary btn-lg" %>
<% else %>
  <!-- 未ログインユーザーには「戻る」ボタンと「ユーザー登録」ボタンを表示 -->
  <div class="d-grid gap-2" style="max-width: 400px; margin: 0 auto;">
    <%= link_to "もっと試したい", signup_path,
        class: "btn btn-warning px-4 text-white" %>
    <%= link_to "戻る", new_dog_path,
        class: "btn btn-secondary btn-lg" %>
  </div>
    <% end %>
    </div>
  </div>
</div>