<div class="container mt-5">
  <h2 class="text-center mb-4 fw-bold">🔍ブックマーク一覧🔍</h2>

  <div class="row g-4">
    <% if @bookmark_recipes.present? %>
    <% @bookmark_recipes.each do |recipe| %>
      <div class="col-md-4">
        <div class="card recipe-card h-100 shadow-sm p-4 text-center d-flex flex-column">
          <h5 class="fw-bold mb-3"><%= recipe.name %></h5>
          <p class="text-muted small mb-4">
            <%= recipe.description %>
          </p>

          <%= link_to "詳細を見る",
                recipe_path(recipe),
                class: "btn btn-warning rounded-pill px-4 text-white mt-auto" %>
        </div>
      </div>
    <% end %> 
    <% else %>
      <p class="text-center">ブックマークしたレシピがありません</p>
    <% end %>
  </div>

    <div class="text-center mt-5">
      <%= link_to "ホームに戻る", dashboard_path,
          class: "btn btn-warning rounded-pill px-5 fw-bold text-white shadow-sm" %>
   
    </div>
  </div>
</div>