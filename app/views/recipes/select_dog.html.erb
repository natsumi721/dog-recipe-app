<div class="container mt-5">
  <div class="text-center mb-5">
    <h1 class="display-4">どのわんちゃんのレシピを見ますか?</h1>
    <p class="lead">レシピを見たい愛犬を選択してください</p>
  </div>

  <div class="row justify-content-center">
    <% @dogs.each do |dog| %>
      <div class="col-md-6 mb-4">
        <div class="card shadow-sm">
          <div class="card-body">
            <div class="d-flex align-items-center">
              <i class="bi bi-heart-fill" style="font-size: 3rem; color: #FF8C00;"></i>
              <div class="ms-4 flex-grow-1">
                <h3 class="card-title mb-2"><%= dog.name %></h3>
                <p class="card-text text-muted mb-0">
                  <%= dog.age_stage_i18n %> / <%= dog.size_i18n %> / <%= dog.body_type_i18n %> / <%= dog.allergies_i18n %>
                </p>
                </p>
              </div>
              <%= link_to "レシピを見る", recipes_path(dog_id: dog.id), class: "btn btn-warning" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="back-button-container">
    <%= link_to "戻る", dashboard_path, class: "back-button" %>
  </div>
</div>
