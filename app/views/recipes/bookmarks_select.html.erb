<div class="container mt-5">
  <div class="text-center mb-5">
    <h1 class="display-4">どのわんちゃんのブックマークをみますか?</h1>
    <p class="lead">愛犬を選択してください</p>
  </div>

  <div class="row justify-content-center">
    <% @dogs.each do |dog| %>
      <div class="col-md-6 mb-4">
        <div class="card shadow-sm">
          <div class="card-body">
            <div class="d-flex align-items-center">
              <i class="bi bi-heart-fill" style="font-size: 3rem; color: #FF8C00;"></i>
              <div class="ms-4 flex-grow-1">
                <h3 class="card-title mb-2"><%= dog.name %></h3>
              </div>
              <%= link_to "選択する", bookmarks_recipes_path(dog_id: dog.id), class: "btn btn-warning" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="text-center mt-4">
    <%= link_to "戻る", dashboard_path, class: "btn btn-secondary btn-lg" %>
  </div>
</div>