<div class="container mt-5" style="max-width: 600px;">
  <div class="card shadow p-4 rounded-4">

    <h2 class="text-center mb-4 fw-bold">健康プロフィールの作成</h2>

    <%= form_with(model: dog, local: true, id: "dog-form") do |f| %>

      <!-- 名前 -->
      <div class="mb-4">
        <%= f.label :name, "愛犬のお名前", class: "form-label fw-bold" %>
        <%= f.text_field :name, class: "form-control form-control-lg rounded-pill" %>
      </div>

      <!-- サイズ -->
      <div class="mb-4">
        <label class="form-label fw-bold">サイズ</label>
        <div class="d-flex gap-2">
          <% Dog.sizes.keys.each do |size| %>
            <%= f.radio_button :size, size, class: "btn-check", id: "dog_size_#{size}" %>
            <%= f.label "size_#{size}", size_i18n(size), class: "btn btn-outline-warning rounded-pill px-4" %>
          <% end %>
        </div>
      </div>

      <!-- 年齢 -->
      <div class="mb-4">
        <label class="form-label fw-bold">年齢</label>
        <div class="d-flex gap-2">
          <% Dog.age_stages.keys.each do |age| %>
            <%= f.radio_button :age_stage, age, class: "btn-check", id: "dog_age_stage_#{age}" %>
            <%= f.label "age_stage_#{age}", age_i18n(age), class: "btn btn-outline-warning rounded-pill px-4" %>
          <% end %>
        </div>
      </div>

      <!-- 体型 -->
      <div class="mb-4">
        <label class="form-label fw-bold">体型</label>
        <div class="d-flex gap-2">
          <% Dog.body_types.keys.each do |body| %>
            <%= f.radio_button :body_type, body, class: "btn-check", id: "dog_body_type_#{body}" %>
            <%= f.label "body_type_#{body}", body_i18n(body), class: "btn btn-outline-warning rounded-pill px-4" %>
          <% end %>
        </div>
      </div>

      <!-- 活発度 -->
      <div class="mb-4">
        <label class="form-label fw-bold">活発度</label>
        <div class="d-flex gap-2">
          <% Dog.activity_levels.keys.each do |act| %>
            <%= f.radio_button :activity_level, act, class: "btn-check", id: "dog_activity_level_#{act}" %>
            <%= f.label "activity_level_#{act}", activity_i18n(act), class: "btn btn-outline-warning rounded-pill px-4" %>
          <% end %>
        </div>
      </div>

      <!-- アレルギー -->
      <div class="mb-4">
        <label class="form-label fw-bold">アレルギー</label>

         <div class="d-flex flex-wrap gap-2">
          <% Dog::ALLERGIES.each_with_index do |item, i| %>
             <% input_id = "allergy_#{i}" %>

            <%= f.check_box :allergies,
                  { multiple: true, class: "btn-check", id: input_id },
                  item,
                  nil %>

            <%= label_tag input_id,
                  item,
                  class: "btn btn-outline-warning rounded-pill px-4" %>
          <% end %>
        </div>
      </div>
      
        <!-- 画像アップロード -->
        <% if current_user %>
          <div class="mb-3 text-start">
            <%= f.label :avatar, "愛犬の写真" %>

        <!--  編集時のみ現在の画像を表示 -->
           <% if dog.persisted? && dog.avatar.attached? %>
          <div class="mb-3">
          <% if dog.avatar.persisted? %>
            <%= image_tag dog.avatar,
                alt: "#{dog.name}の写真",
                class: "rounded",
                style: "max-width: 200px; height: auto; border: 2px solid #dee2e6;" %>
          <% else %>
            <p class="text-muted">画像をアップロード中...</p>
          <% end %>
    
           <!--  画像を削除するチェックボックス（編集時のみ） -->
            <div class="form-check mt-2 mb-3">
              <%= f.check_box :remove_avatar, class: "form-check-input" %>
              <%= f.label :remove_avatar, "この画像を削除する", class: "form-check-label" %>
            </div>
           <% end %>

          <!--  画像が未登録の場合のメッセージ -->
        <% if dog.persisted? && !dog.avatar.attached? %>
          <div class="mb-3">
            <p class="text-muted">画像が登録されていません</p>
          </div>
         <% end %>

         <!--  ファイル選択フィールド -->
         <%= f.file_field :avatar, accept: "image/png, image/jpg, image/jpeg", class: "form-control" %>
        <small class="text-muted">
          PNG、JPG、JPEG形式、5MB以下
          <% if dog.new_record? %>
            （未選択の場合はデフォルト画像が使用されます）
          <% end %>
        </small>
      </div>
      <% end %>

        <!-- 送信ボタン（IDを追加） -->
      <div class="d-grid">
        <%= f.submit dog.new_record? ? "登録する" : "更新する",
            id: "dog-submit-button",
            class: "btn btn-warning btn-lg rounded-pill fw-bold text-white" %>
      </div>

        <!--  ローディング表示（初期状態は非表示） -->
      <div id="loading-indicator" class="hidden text-center mt-4">
        <div class="d-flex justify-content-center align-items-center">
          <svg class="animate-spin" style="width: 40px; height: 40px; color: #ffc107;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
        </div>
        <p class="text-warning fw-bold mt-3">画像をアップロード中...</p>
        <p class="text-muted small">少々お待ちください</p>
      </div>

    <% end %>

            <% if dog.persisted? %>
              <div class="text-center mt-3">
                <%= button_to "#{dog.name}ちゃんの情報を削除",
                    dog_path(dog),
                    method: :delete,
                    data: { turbo_confirm: "本当に削除しますか？", turbo:true },
                    class: "btn btn-outline-danger rounded-pill px-4" %>
              </div>
            <% end %>

    <div class="text-center mt-4">
      <%= link_to "← 戻る", root_path,
          class: "btn btn-secondary btn-lg" %>
    </div>
  </div>
</div>
