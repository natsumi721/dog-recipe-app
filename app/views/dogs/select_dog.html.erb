<div class="container mt-5">
  <div class="text-center mb-5">
    <h1 class="display-4">どのわんちゃんの情報を変更しますか?</h1>
    <p class="lead">変更したい愛犬を選択してください</p>
  </div>

  <div class="row justify-content-center">
    <% @dogs.each do |dog| %>
      <div class="col-md-6 mb-4">
        <div class="card shadow-sm">
          <div class="card-body">
            <div class="d-flex align-items-center">
              <i class="bi bi-heart-fill" style="font-size: 3rem; color: #FF8C00;"></i>
              <div class="ms-4 flex-grow-1">
                <h3 class="card-title mb-2"><%= dog.name %></h3>
                <p class="card-text text-muted mb-0">
                  <%= dog.age_stage %> / <%= dog.size %> / <%= dog.body_type %>
                </p>
              </div>
              <%= link_to "情報を変更", edit_dog_path(dog), class: "btn btn-warning" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="text-center mt-4">
    <%= link_to "ダッシュボードに戻る", dashboard_path, class: "btn btn-secondary" %>
  </div>
</div>