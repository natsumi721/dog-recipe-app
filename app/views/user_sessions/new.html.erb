<div class="top-container">

  <h1 class="accent">ログイン</h1>
  
  <p class="sub-text"></p>

  <div class="recipe-card p-4 mt-4" style="max-width:400px;margin:auto;">
    <%= form_with url: login_path, local: true do |f| %>

      <div class="mb-3 text-start">
        <%= f.label :email, "メールアドレス" %>
        <%= f.email_field :email, class: "form-control" %>
      </div>

      <div class="mb-3 text-start">
        <%= f.label :password, "パスワード" %>
        <%= f.password_field :password, class: "form-control" %>
      </div>

      <%= f.submit "ログインする", class: "cta-button" %>

    <% end %>
    
    <!-- パスワードリセットのリンクをフォームの外に移動 -->
    <div class="text-center mt-3">
      <%= link_to "パスワード忘れた方", new_password_reset_path, class: "primary-button" %>
    </div>

    <!-- Google OAuth ログインボタン -->
    <div class="text-center mt-4">
      <p class="note">または</p>
      <%= link_to auth_at_provider_path(provider: :google), class: "secondary-button d-flex align-items-center justify-content-center gap-2", style: "max-width:400px;margin:auto;" do %>
        <%= image_tag "google-icon.png", alt: "Google", style: "width:20px;height:20px;" %>
        <span>Google でログイン</span>
      <% end %>
    </div>

  </div>

  <p class="note mt-4">
    アカウントをお持ちでないですか？
  </p>
  <div class="signup-buttons">
  <%= link_to "新規登録する", signup_path, class: "secondary-button" %>
  <%= link_to "戻る", root_path, class: "back-button" %>
</div>