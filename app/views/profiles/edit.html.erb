<div class="container mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold mb-6">プロフィール編集</h1>

  <%= form_with model: @user, url: profile_path, method: :patch, local: true do |f| %>
    <% if @user.errors.any? %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
        <ul>
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mb-4">
      <%= f.label :first_name, "姓", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.text_field :first_name, class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
    </div>

    <div class="mb-4">
      <%= f.label :last_name, "名", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.text_field :last_name, class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
    </div>

    <div class="mb-4">
      <%= f.label :nickname, "ニックネーム", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.text_field :nickname, class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
    </div>

    <div class="flex gap-4">
      <%= f.submit "更新する", class: "bg-blue-500 hover:bg-blue-600 text-white font-bold py-2 px-4 rounded" %>
      <%= link_to "キャンセル", root_path, class: "bg-gray-500 hover:bg-gray-600 text-white font-bold py-2 px-4 rounded" %>
    </div>
  <% end %>
</div>