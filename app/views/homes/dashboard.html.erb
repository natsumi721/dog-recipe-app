<div class="container mt-5">
  <div class="text-center mb-5">

    <% if current_user.dogs.present? %>
      <!-- 犬が登録されている場合 -->
      <div style="max-width: 800px; margin: 0 auto;">
        <!-- 中央寄せ -->
        <div class="d-flex align-items-center justify-content-center mb-4">

          <!-- 左側：画像エリア -->
          <div class="me-4" style="width: 120px; height: 120px; flex-shrink: 0;">

            <% if current_user.dogs.count == 1 %>
              <!-- 1匹 なら普通表示 -->
              <%= dog_avatar(
                    current_user.dogs.first,
                    alt: "#{current_user.dogs.first.name}の写真",
                    class: "rounded-circle",
                    style: "width: 120px; height: 120px; object-fit: cover; border: 3px solid #dee2e6;"
                  ) %>

            <% else %>
              <!--  複数登録なら Swiper -->
              <div class="swiper top-dog-swiper" style="width: 120px; height: 120px;">
                <div class="swiper-wrapper">
                  <% current_user.dogs.each do |dog| %>
                    <div class="swiper-slide d-flex justify-content-center align-items-center">
                      <%= dog_avatar(
                            dog,
                            alt: "#{dog.name}の写真",
                            class: "rounded-circle",
                            style: "width: 120px; height: 120px; object-fit: cover; border: 3px solid #dee2e6;"
                          ) %>
                    </div>
                  <% end %>
                </div>

                <!-- ナビゲーション -->
                <div class="swiper-button-prev" style="left: -30px;"></div>
                <div class="swiper-button-next" style="right: -30px;"></div>

                <!-- ページネーション -->
                <div class="swiper-pagination" style="bottom: -20px;"></div>
              </div>
            <% end %>

          </div>

          <!--  右側：テキスト（中央寄せ） -->
          <div class="text-center">
            <h1 class="display-4 mb-2">
              ようこそ、<%= current_user.first_name %>さん!
            </h1>

            <p class="lead mb-0">
              <% if current_user.dogs.count == 1 %>
                <%= current_user.dogs.first.name %>ちゃんと一緒に
              <% else %>
                <%= current_user.dogs.count %>匹の愛犬と一緒に
              <% end %>
            </p>
          </div>

        </div>
      </div>

    <% else %>
      <!-- 犬が登録されていない場合 -->
      <div style="max-width: 800px; margin: 0 auto;">
        <!-- 中央寄せ -->
        <div class="d-flex align-items-center justify-content-center mb-4">

          <%= image_tag 'nikukyuu.jpeg',
                alt: '肉球の写真',
                class: 'rounded-circle me-4',
                style: 'width: 120px; height: 120px; object-fit: cover; border: 3px solid #dee2e6; flex-shrink: 0;' %>

          <!-- テキスト中央寄せ -->
          <div class="text-center">
            <h1 class="display-4 mb-2">
              ようこそ、<%= current_user.first_name %>さん!
            </h1>
            <p class="lead mb-0 text-muted">
              愛犬を登録してください
            </p>
          </div>

        </div>
      </div>
    <% end %>

    <p class="lead text-center">次のアクションを選択してください</p>

  </div>


  <div class="row justify-content-center">

    <!-- レシピを見る -->
    <%= render "homes/card",
      icon: "bi-book",
      title: "レシピを見る",
      text: "愛犬に合ったレシピを探しましょう" do %>

      <% if current_user.dogs.exists? %>
        <% if current_user.dogs.count == 1 %>
          <%= link_to "レシピを見る",
            recipes_path(dog_id: current_user.dogs.first.id),
            class: "btn btn-warning btn-lg" %>
        <% else %>
          <%= link_to "レシピを見る",
            select_dog_recipes_path,
            class: "btn btn-warning btn-lg" %>
        <% end %>
      <% else %>
        <p class="text-muted">愛犬情報を登録してください</p>
        <%= link_to "愛犬情報を登録",
          new_dog_path,
          class: "btn btn-outline-warning" %>
      <% end %>

    <% end %>


    <!-- 愛犬情報 -->
    <%= render "homes/card",
      icon: "bi-heart",
      title: "愛犬情報",
      text: "愛犬の情報を管理しましょう" do %>

      <% if current_user.dogs.exists? %>
        <% if current_user.dogs.count == 1 %>
          <%= link_to "情報を変更",
            edit_dog_path(current_user.dogs.first),
            class: "btn btn-warning btn-lg" %>
        <% else %>
          <%= link_to "情報を変更",
            select_dog_dogs_path,
            class: "btn btn-warning btn-lg" %>
        <% end %>
      <% else %>
        <%= link_to "情報を登録",
          new_dog_path,
          class: "btn btn-warning btn-lg" %>
      <% end %>

    <% end %>


    <!-- レシピ投稿 -->
    <%= render "homes/card",
      icon: "bi-pencil-square",
      title: "レシピを投稿",
      text: "あなたのレシピをシェアしましょう" do %>

      <%= link_to "投稿する",
        select_action_recipes_path, class: "btn btn-warning btn-lg" %>

    <% end %>


    <!-- 愛犬追加 -->
    <%= render "homes/card",
      icon: "bi-plus-circle",
      title: "愛犬の追加",
      text: "新しい愛犬を登録しましょう" do %>

      <%= link_to "愛犬を追加",
        new_dog_path,
        class: "btn btn-warning btn-lg" %>

    <% end %>


    <!-- ブックマーク -->
    <%= render "homes/card",
      icon: "bi-bookmark",
      title: "ブックマーク",
      text: "お気に入りのレシピをみよう" do %>

      <%= link_to "レシピをみる",
        bookmarks_recipes_path,
        class: "btn btn-warning btn-lg" %>

    <% end %>


    <!-- 使い方 -->
    <%= render "homes/card",
      icon: "bi-question-circle",
      title: "アプリの使い方",
      text: "使いこなすための秘訣" do %>

      <%= link_to "使い方を見る",
        "#",
        class: "btn btn-warning btn-lg" %>

    <% end %>

    <% if current_user.admin? %>
  <!-- 承認待ちレシピ -->
  <%= render "homes/card",
      icon: "bi-list-check",
      title: "承認待ちレシピ",
      text: "まだ承認されていないレシピを確認" do %>

      <%= link_to "確認する", admin_recipes_path, class: "btn btn-warning btn-lg" %>
  <% end %>

  <!-- 承認済みレシピ -->
  <%= render "homes/card",
      icon: "bi-check-circle",
      title: "承認済みレシピ",
      text: "承認済みレシピの一覧を見る" do %>

      <%= link_to "確認する", published_admin_recipes_path, class: "btn btn-warning btn-lg" %>
  <% end %>
<% end %>

  </div>
</div>