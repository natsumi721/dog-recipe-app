<div class="col-md-6 mb-4">
  <div class="card h-100 shadow-sm">
    <div class="card-body text-center">

      <i class="bi <%= icon %>" style="font-size: 3rem; color: #FF8C00;"></i>

      <h3 class="card-title mt-3"><%= title %></h3>

      <p class="card-text"><%= text %></p>

      <%= yield %>

    </div>
  </div>
</div>